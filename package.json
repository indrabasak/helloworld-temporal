  "type": "module",
  "scripts": {
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "build:hello-world": "tsc --project src/hello-world",
    "start:hello-world": "node dist/hello-world/worker.js",
    "start:hello-world:workflow": "node dist/hello-world/client.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indrabasak/helloworld-temporal.git"
  },
